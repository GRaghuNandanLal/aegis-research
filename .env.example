# === LLM (any OpenAI-compatible provider) ===
# Get an OpenAI key at https://platform.openai.com/api-keys
# OR a free Groq key at https://console.groq.com/keys (recommended for demos)
OPENAI_API_KEY=YOUR_API_KEY_HERE

# Optional: point at Groq / Azure OpenAI / Together / Fireworks / local vLLM
# Examples:
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI default: gpt-4o-mini. Groq default suggestion: llama-3.3-70b-versatile.
OPENAI_MODEL=gpt-4o-mini

# === Search tool (optional; falls back to DuckDuckGo then a deterministic mock) ===
# Free 1000 searches/month at https://app.tavily.com
# TAVILY_API_KEY=YOUR_TAVILY_KEY_HERE

# === Runtime limits / guardrails ===
MAX_INPUT_CHARS=4000
MAX_SUBQUESTIONS=5
MAX_CRITIQUE_LOOPS=2
MAX_TOOL_CALLS=12
REQUEST_TIMEOUT_S=90
# Comma-separated hostname allowlist for the web_search tool, or * for any.
ALLOW_TOOL_DOMAINS=*
# Force the offline mock corpus (useful for demos / CI when search is flaky).
ENABLE_SEARCH_MOCK=false

# === Server ===
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
